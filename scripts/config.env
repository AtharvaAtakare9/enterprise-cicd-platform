# Nothing below NEEDS to be edited. Defaults work out of the box.
# DATABASE_URL is built automatically from the new Terraform RDS module.
# JWT_SECRET is auto-generated by the script if left blank.
# Only run 'aws configure' once before running bootstrap-all.sh.

AWS_REGION="us-east-1"
TF_STATE_BUCKET=expense-tracker-tfstate-259151461533
CLUSTER_NAME="expense-tracker-eks"
ECR_REPO_NAME="expense-tracker-backend"
KEY_PAIR_NAME="New-key"

# Leave blank to auto-generate a secure random value.
JWT_SECRET=""
JWT_EXPIRY="1d"
